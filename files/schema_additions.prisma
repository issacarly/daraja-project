// Place it alongside your existing User, Student, Teacher models
// ─────────────────────────────────────────────────────────────────────────────

model Institution {
  id        Int      @id @default(autoincrement())
  uic       String   @unique @db.VarChar(4)
  name      String   @db.VarChar(255)
  classes   Int      @default(1)
  createdAt DateTime @default(now())

  // Relations — every user registered with this UIC belongs here
  users     User[]

  @@map("institutions")
}

